//File Title: Physical Constraints file for Tang Nano 9K
//GOWIN Version: 1.9.9
//Part Number: GW1NR-LV9QN88PC6/I5
//Device: GW1NR-9C
//Created Time: 2026

// Clock - 27MHz oscillator (directly from crystal)
IO_LOC "clk" 52;
IO_PORT "clk" PULL_MODE=NONE IO_TYPE=LVCMOS33;

// Reset button (active low) - Button S1 (KEY1)
// Bank 3 = 1.8V, use LVCMOS18
IO_LOC "rst_n" 4;
IO_PORT "rst_n" PULL_MODE=UP IO_TYPE=LVCMOS18;

// Run/Halt button - Button S2 (KEY2)
IO_LOC "btn_run" 3;
IO_PORT "btn_run" PULL_MODE=UP IO_TYPE=LVCMOS18;

// Onboard LEDs (active low) - Bank 3 = 1.8V
IO_LOC "led[0]" 10;
IO_LOC "led[1]" 11;
IO_LOC "led[2]" 13;
IO_LOC "led[3]" 14;
IO_LOC "led[4]" 15;
IO_LOC "led[5]" 16;
IO_PORT "led[0]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;
IO_PORT "led[1]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;
IO_PORT "led[2]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;
IO_PORT "led[3]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;
IO_PORT "led[4]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;
IO_PORT "led[5]" PULL_MODE=NONE DRIVE=8 IO_TYPE=LVCMOS18;

// Optional UART debug pins
IO_LOC "uart_rx" 18;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33;
IO_LOC "uart_tx" 17;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33;


// PMOD connector pins: 25, 26, 27, 28, 29, 30, 31, 32
IO_LOC "gpio[0]" 25;
IO_LOC "gpio[1]" 26;
IO_LOC "gpio[2]" 27;
IO_LOC "gpio[3]" 28;
IO_LOC "gpio[4]" 29;
IO_LOC "gpio[5]" 30;
IO_LOC "gpio[6]" 31;
IO_LOC "gpio[7]" 32;
IO_PORT "gpio[0]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[1]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[2]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[3]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[4]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[5]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[6]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
IO_PORT "gpio[7]" PULL_MODE=NONE IO_TYPE=LVCMOS33;
